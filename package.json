{
  "name": "uijeong-watch",
  "type": "module",
  "private": true,
  "scripts": {
    "gen:data": "node scripts/gen-photos.mjs && node scripts/gen-committees.mjs && node scripts/gen-bills.mjs && node scripts/gen-insights.mjs && node scripts/gen-districts.mjs && node scripts/gen-avatars.mjs",
    "build": "rm -rf .output .nuxt/cache node_modules/.cache && npm run gen:data && nuxt build",
    "dev": "nuxt dev --port 4191",
    "generate": "nuxt generate",
    "preview": "wrangler dev",
    "deploy": "nuxt build && wrangler deploy && node scripts/purge-kv.mjs",
    "purge:kv": "node scripts/purge-kv.mjs",
    "cf:dev": "nuxt build && wrangler dev",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.469.0",
    "nuxt": "^4.4.7",
    "reka-ui": "^2.9.9",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@nuxtjs/color-mode": "^4.0.0",
    "@tailwindcss/vite": "^4.1.13",
    "@vueuse/nuxt": "^12.8.2",
    "shadcn-nuxt": "^2.4.0",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.3"
  }
}

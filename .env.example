# 열린국회정보 Open API 인증키 (https://open.assembly.go.kr 에서 발급)
# 로컬 개발용. 운영(Cloudflare Workers)에서는 secret 으로 주입:
#   bunx wrangler secret put NUXT_ASSEMBLY_API_KEY
API_KEY=your_assembly_api_key_here

# 로컬 dev 포트
PORT=4191
NITRO_PORT=4191

# Kakao 지도 JavaScript 키 (지역별 의원 지도)
KAKAO_MAP_KEY=your_kakao_js_key
